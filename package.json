{
  "name": "t1dine-platform",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "typecheck": "pnpm --filter=@t1dine/domain --filter=@t1dine/food-schema --filter=@t1dine/nutrition --filter=@t1dine/design-tokens --filter=@t1dine/dose-engine exec tsc --noEmit",
    "typecheck:dose-engine": "pnpm --filter=@t1dine/dose-engine exec tsc --noEmit",
    "typecheck:mobile": "pnpm --filter=@t1dine/mobile exec tsc --noEmit",
    "typecheck:api": "pnpm --filter=@t1dine/api exec tsc --noEmit",
    "typecheck:admin": "pnpm --filter=@t1dine/admin exec tsc --noEmit",
    "lint": "eslint packages",
    "test": "vitest run",
    "demo": "vitest run --config vitest.demo.config.ts",
    "dev:api": "pnpm --filter=@t1dine/api dev",
    "dev:admin": "pnpm --filter=@t1dine/admin dev",
    "dev:mobile": "pnpm --filter=@t1dine/mobile web",
    "boundaries": "depcruise packages services apps --config .dependency-cruiser.cjs && node scripts/check_dose_engine_isolation.mjs",
    "validate": "python scripts/validate_repo.py",
    "check": "pnpm typecheck && pnpm lint && pnpm test && pnpm boundaries && pnpm validate"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "tsx": "^4.19.2",
    "@types/node": "^24.0.0",
    "dependency-cruiser": "^16.0.0",
    "eslint": "^9.18.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.20.0",
    "vitest": "^3.0.0"
  }
}
